---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import zikrIBatinCover from '../assets/zikr-i-batin.webp';
import localData from '../data/home.json';

interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  intro: string;
  introHtml: string;
  resumeUrl: string;
  socials: Social[];
}

const isApiLive = import.meta.env.PROD;
const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

let data: ProfileData;

if (isApiLive && BASE_URL) {
  try {
    const response = await fetch(`${BASE_URL}/home`);

    if (!response.ok) {
      throw new Error('Network response was not ok');
    }

    data = await response.json();
  } catch (error) {
    console.error(
      'API Fetch failed, falling back to mock data',
      error
    );

    data = localData as ProfileData;
  }
} else {
  data = localData as ProfileData;
}

const {
  name,
  intro,
  resumeUrl,
  socials
} = data;
---

<section
  id="home"
  class="flex min-h-[62vh] flex-col items-center justify-center gap-1 text-center section-container md:pt-30"
>
  <div
    class="relative mb-2 group reveal-content"
    style="animation-delay: 100ms;"
  >
    <div
      class="w-20 h-20 overflow-hidden border-2 rounded-full balloon-float md:w-24 md:h-24 border-accent shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)]"
    >
      <img
        src="/artist-logo.webp"
        alt="Berk Köksal artist logo"
        class="object-cover w-full h-full scale-110"
        loading="eager"
        decoding="async"
      />
    </div>

    <div
      class="absolute top-0 left-0 -z-10 w-full h-full rounded-full balloon-float bg-accent blur-[80px] opacity-20"
    >
    </div>
  </div>

  <div
    class="reveal-content"
    style="animation-delay: 200ms;"
  >
    <p class="font-light leading-relaxed font-body text-gray">
      Official Artist Website
    </p>
  </div>

  <div
    class="relative z-0 px-6 mx-auto sm:px-14 md:px-18 lg:px-40 max-w-360 reveal-content"
    style="animation-delay: 300ms;"
  >
    <h1
      class="text-5xl font-bold tracking-tight md:text-7xl font-heading text-maintext"
    >
      {name}
    </h1>

    <br />

    <p
      class="text-lg leading-relaxed font-body text-gray"
      set:html={intro}
    />
  </div>

  <div
    class="mt-8 mb-4 reveal-content"
    style="animation-delay: 400ms;"
  >
    <a
      href={resumeUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Listen on Spotify"
      class="relative inline-flex items-center justify-center px-10 py-3 transition-all duration-300 border rounded-full group bg-white/5 border-accent/50 text-maintext font-body bg-accent/10 md:shadow-none md:hover:shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)] hover:scale-105"
    >
      <div class="flex items-center gap-3">
        <Icon
          name="mdi:spotify"
          class="w-5 h-5 transition-colors duration-300 text-maintext group-hover:text-accent"
        />

        <div class="flex flex-col items-start text-left">
          <span
            class="text-sm font-medium tracking-wide md:text-base"
          >
            Listen on Spotify
          </span>

          <span
            class="text-[10px] text-subtext font-light whitespace-nowrap"
          >
            Official Artist Page
          </span>
        </div>
      </div>

      <div
        class="absolute inset-0 -z-10 rounded-full blur-md bg-accent/20 opacity-100 transition-opacity duration-500 md:opacity-0 md:group-hover:opacity-100"
      >
      </div>
    </a>
  </div>

  <div
    class="flex gap-6 mt-4 reveal-content"
    style="animation-delay: 500ms;"
  >
    {
      socials
        .filter(
          (social) =>
            social.url &&
            social.url !== '#' &&
            social.url !== ''
        )
        .map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.name}
            class="relative flex flex-col items-center justify-center transition-all duration-300 group hover:scale-110"
          >
            <Icon
              name={social.icon}
              class="w-8 h-8 transition-colors duration-300 text-maintext group-hover:text-accent"
            />

            <span
              class="absolute -bottom-6 scale-0 opacity-0 transition-all duration-300 text-xs text-accent font-body group-hover:scale-100 group-hover:opacity-100"
            >
              {social.name}
            </span>
          </a>
        ))
    }
  </div>
</section>

<section class="-mt-6 mb-6">
  <div
    class="rounded-[2rem] border border-accent/20 bg-accent/5 p-8 backdrop-blur-xl"
  >
    <div class="flex items-center gap-2 mb-6">
      <Icon
        name="mdi:spotify"
        class="w-5 h-5 text-green-400"
      />

      <span
        class="text-xs font-semibold text-green-400 uppercase tracking-[0.35em]"
      >
        Latest Release
      </span>
    </div>

    <div
      class="grid items-center grid-cols-1 gap-10 lg:grid-cols-[320px_1fr]"
    >
      <a
        href="/albums/zikr-i-batin"
        class="group"
      >
        <Image
          src={zikrIBatinCover}
          alt="ZIKR-I BATIN album cover by Berk KÖKSAL"
          widths={[320, 480, 640]}
          sizes="(max-width: 1023px) 100vw, 320px"
          format="webp"
          quality={82}
          loading="lazy"
          decoding="async"
          class="w-full rounded-3xl shadow-2xl transition duration-500 group-hover:scale-[1.02]"
        />
      </a>

      <div>
        <div
          class="mb-2 text-sm uppercase tracking-[0.35em] text-accent"
        >
          ALBUM • 2026
        </div>

        <h2 class="mb-4 text-5xl font-bold">
          ZIKR-I BATIN
        </h2>

        <p
          class="mb-8 text-lg leading-8 text-white/70"
        >
          The latest chapter in the Neo-Sacred Zikr universe,
          combining sacred choirs, orchestral textures,
          contemplative remembrance and modern production.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="https://open.spotify.com/intl-tr/album/64iYKr2840EvDibapiDZb9"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-full border border-[#1DB954]/30 bg-[#1DB954]/10 px-7 py-4 font-semibold text-white transition hover:bg-[#1DB954]/20"
          >
            <Icon
              name="mdi:spotify"
              class="w-5 h-5 text-[#1DB954]"
            />

            Listen on Spotify
          </a>

          <a
            href="/albums/zikr-i-batin"
            class="inline-flex items-center gap-3 px-7 py-4 font-semibold text-white transition border rounded-full border-accent/20 bg-accent/10 hover:bg-accent/20"
          >
            View Album
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation:
      revealIn
      0.8s
      cubic-bezier(0.2, 0.8, 0.2, 1)
      forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .balloon-float {
    will-change: transform;
    animation:
      floating-balloon
      8s
      ease-in-out
      infinite;
  }

  @keyframes floating-balloon {
    0% {
      transform:
        translate(0, 0)
        rotate(0deg);
    }

    33% {
      transform:
        translate(3px, -8px)
        rotate(1deg);
    }

    66% {
      transform:
        translate(-3px, -4px)
        rotate(-1deg);
    }

    100% {
      transform:
        translate(0, 0)
        rotate(0deg);
    }
  }
</style>