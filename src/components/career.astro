---
import QuranResearch from "./quran-research.astro";

const stats = [
  { value: "9", label: "Albums" },
  { value: "100+", label: "ZIKR TRACKS" },
  { value: "2024", label: "Neo-Sacred Zikr Journey" },
  { value: "One-Man", label: "Production Vision" },
];
---

<section
  id="career"
  class="section-container max-w-6xl mx-auto overflow-hidden"
>
  <div class="container mx-auto biography-section">
    <div class="mb-14">
      <h2
        class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4"
      >
        <span class="text-accent">/</span>
        Biography
      </h2>

      <p class="text-subtext font-body text-sm max-w-2xl">
        Composer, guitarist, music producer and founder of Neo-Sacred Zikr.
      </p>
    </div>

    <div
      class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-10 items-center"
    >
      <div class="relative group">
        <div
          class="absolute -inset-4 rounded-[2rem] bg-accent/20 blur-3xl opacity-40 group-hover:opacity-70 transition-opacity duration-700"
        ></div>

        <img
          src="/artist/berk-portrait.webp"
          alt="Berk Köksal portrait"
          class="relative w-full rounded-[2rem] border border-accent/20 shadow-2xl shadow-accent/10 object-cover"
        />
      </div>

      <div class="space-y-6">
        <div>
          <p
            class="text-accent text-xs uppercase tracking-[0.35em] font-bold mb-4"
          >
            Official Artist Biography
          </p>

          <h3
            class="text-4xl md:text-5xl font-heading font-bold text-maintext leading-tight"
          >
            Berk KÖKSAL
          </h3>

          <p class="text-accent/90 mt-3 font-body">
            Composer • Guitarist • Music Producer • Founder of Neo-Sacred Zikr
          </p>
        </div>

        <div class="space-y-4 text-subtext font-body leading-8">
          <p>
            Berk KÖKSAL is a composer, guitarist, vocalist, songwriter,
            arranger, music producer, mix and mastering engineer, software
            engineer and Quran researcher.
          </p>

          <p>
            His musical vision is centered on Neo-Sacred Zikr: a contemporary
            sacred music universe that brings together zikr, sacred choirs,
            symphonic orchestration, progressive rock, ambient sound design,
            rap vocals and modern production techniques.
          </p>

          <p>
            For Berk KÖKSAL, music is more than a career. It is a path of
            submission, remembrance and a call to glorify the One GOD through
            the sounds of the modern age.
          </p>
        </div>

        <a
          href="/full-biography"
          class="group flex w-full items-center justify-between rounded-2xl border border-accent/40 bg-accent/10 px-6 py-5 text-accent transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:bg-accent hover:text-background hover:shadow-[0_16px_45px_rgba(167,139,250,0.22)]"
          aria-label="Read Berk Köksal's full biography"
        >
          <div>
            <p
              class="text-[11px] font-bold uppercase tracking-[0.3em] opacity-80"
            >
              Continue the Story
            </p>

            <p class="mt-2 text-xl font-heading font-bold md:text-2xl">
              Read Full Biography
            </p>
          </div>

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7 shrink-0 transition-transform duration-300 group-hover:translate-x-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"
            />
          </svg>
        </a>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-2">
          {
            stats.map((stat) => (
              <div class="rounded-2xl border border-accent/15 bg-accent/5 p-4 text-center">
                <div class="text-2xl font-heading font-bold text-maintext">
                  {stat.value}
                </div>

                <div class="text-[11px] text-subtext uppercase tracking-wider mt-1">
                  {stat.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <QuranResearch />

    <div
      class="mt-28 md:mt-32 relative overflow-hidden rounded-[2rem] border border-accent/20 bg-accent/5"
    >
      <img
        src="/artist/neo-sacred-zikr-banner.webp"
        alt="Neo-Sacred Zikr banner"
        class="w-full h-[260px] md:h-[420px] object-cover opacity-80"
      />

      <div
        class="absolute inset-0 bg-gradient-to-r from-background via-background/70 to-background/10"
      ></div>

      <div class="absolute inset-0 flex items-center">
        <div class="p-8 md:p-14 max-w-2xl">
          <p
            class="text-accent text-xs uppercase tracking-[0.35em] font-bold mb-4"
          >
            Sacred Music Universe
          </p>

          <h3
            class="text-3xl md:text-5xl font-heading font-bold text-maintext mb-4"
          >
            Neo-Sacred Zikr
          </h3>

          <p class="text-subtext font-body leading-7">
            A new sacred music vision where orchestral choirs, spiritual
            ambience, progressive rock, sacred rap and devotional sound design
            unite around one purpose: remembering and glorifying the One GOD.
          </p>

          <a
            href="/neo-sacred-zikr"
            class="group mt-7 inline-flex items-center gap-3 rounded-full border border-accent/40 bg-background/40 px-6 py-3 font-bold text-accent backdrop-blur-md transition-all duration-300 hover:border-accent hover:bg-accent hover:text-background"
          >
            <span>Explore Neo-Sacred Zikr</span>

            <span
              aria-hidden="true"
              class="transition-transform duration-300 group-hover:translate-x-2"
            >
              →
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .biography-section {
    opacity: 0;
    transform: translateY(24px);
    animation: biographyReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes biographyReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>