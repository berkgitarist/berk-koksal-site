---
import { Icon } from 'astro-icon/components';

const { project } = Astro.props;

const validImages = project.images || [];
const isSlider = validImages.length > 1;
---

<a
  href={project.link}
  aria-label={`${project.title} album page`}
  class="project-card group relative flex flex-col h-full bg-accent/5 border border-accent/10 rounded-3xl overflow-hidden hover:border-accent/40 transition-all duration-500 no-underline"
>
  <div class="aspect-square overflow-hidden relative bg-background/50">
    <div class="absolute inset-0 bg-accent/10 group-hover:bg-transparent transition-colors z-10 pointer-events-none"></div>

    <div class={`w-full h-full relative ${isSlider ? 'image-slider' : ''}`}>
      {
        validImages.length > 0 ? (
          validImages.map((imgSrc: string, index: number) => (
            <img
              src={`/${imgSrc}`}
              alt={project.title}
              class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-[1.04] ${
                index === 0 ? 'opacity-100 z-0' : 'opacity-0 z-[-1]'
              }`}
            />
          ))
        ) : (
          <img
            src="/placeholder.jpeg"
            alt={`${project.title} placeholder`}
            class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-105"
          />
        )
      }
    </div>

    <div class="absolute top-3 right-3 flex gap-2 z-20 pointer-events-none">
      {
        project.platforms.map((p: string) => (
          <div class="p-1.5 bg-background backdrop-blur-md rounded-lg border border-accent/10 text-maintext">
            <Icon name={`mdi:${p}`} class="w-4 h-4" />
          </div>
        ))
      }
    </div>
  </div>

  <div class="p-6 space-y-4 flex flex-col flex-1">
    <div class="flex justify-between items-start gap-4">
      <div>
        <span class="text-accent text-[10px] uppercase tracking-widest font-bold">
          {project.category}
        </span>

        <h3 class="text-xl font-heading font-bold text-maintext mt-1">
          {project.title}
        </h3>
      </div>

      <span class="text-accent/75 group-hover:text-accent transition-colors shrink-0">
        <Icon name="mdi:open-in-new" class="w-6 h-6" />
      </span>
    </div>

    <p class="text-subtext text-sm font-body line-clamp-3 min-h-[72px]">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-2 pt-2 mt-auto">
      {
        project.tech.map((t: string) => (
          <span class="rounded-md text-[10px] px-2 md:px-4 py-1 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent">
            {t}
          </span>
        ))
      }
    </div>
  </div>
</a>

<script>
  function initSliders() {
    const sliders = document.querySelectorAll('.image-slider');

    sliders.forEach((slider) => {
      const images = slider.querySelectorAll('img');
      if (images.length <= 1) return;

      let currentIndex = 0;

      setInterval(() => {
        images[currentIndex].classList.remove('opacity-100', 'z-0');
        images[currentIndex].classList.add('opacity-0', 'z-[-1]');

        currentIndex = (currentIndex + 1) % images.length;

        images[currentIndex].classList.remove('opacity-0', 'z-[-1]');
        images[currentIndex].classList.add('opacity-100', 'z-0');
      }, 3500);
    });
  }

  initSliders();
  document.addEventListener('astro:after-swap', initSliders);
</script>

<style is:global>
  .project-card {
    opacity: 0;
    visibility: hidden;
    transform: translateY(40px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.8s,
      border-color 0.5s ease;
    will-change: transform, opacity;
    cursor: pointer;
  }

  .project-card.reveal {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
</style>